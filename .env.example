# SkillSeed Environment Configuration
# Copy this file to .env and fill in your values

# ------------------------------------------------------------------
# API Authentication (A-1)
# ------------------------------------------------------------------

# Main API key — required by all protected endpoints (X-API-Key header)
SKILLSEED_API_KEY=sk-change-me

# Admin key — required for privileged endpoints like /v1/skills/reload (A-3)
# Defaults to SKILLSEED_API_KEY if not set
SKILLSEED_ADMIN_KEY=sk-admin-change-me

# ------------------------------------------------------------------
# Database (M-4)
# ------------------------------------------------------------------

POSTGRES_USER=skillseed
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://skillseed:change-me-in-production@localhost:5432/skillseed

# ------------------------------------------------------------------
# Redis (B-3)
# ------------------------------------------------------------------

REDIS_PASSWORD=change-me-in-production
REDIS_URL=redis://:change-me-in-production@localhost:6379

# ------------------------------------------------------------------
# LLM
# ------------------------------------------------------------------

# OpenAI API key (used by PromptDistillationProtocol for real LLM calls)
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------
# App settings
# ------------------------------------------------------------------

# Minimum eval score to mark a skill as "bloomed" (0.0 to 1.0)
EVAL_THRESHOLD=0.7

# Path to the root seeder YAML definitions
ROOT_SEEDER_PATH=./seeders

# SkillSeed API base URL (used by SDK and MCP server)
SKILLSEED_API_URL=http://localhost:8000

# Set to "true" to enable /docs, /redoc, /openapi.json (M-3)
# Never enable in production
ENABLE_DOCS=false

# ------------------------------------------------------------------
# Evolution / Shadow eval
# ------------------------------------------------------------------

# Bloom rate below this triggers curriculum revision (0.0 to 1.0)
EVOLUTION_REVISION_THRESHOLD=0.6

# Minimum feedback signals before first revision is attempted
EVOLUTION_MIN_SIGNALS=5

# Max allowed gap between public eval and shadow eval before flagging seeder
SHADOW_EVAL_DRIFT_THRESHOLD=0.2

# Allowed CORS origins, comma-separated (A-2)
# Example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Optional: pre-set agent ID for MCP server sessions
# SKILLSEED_AGENT_ID=your-agent-uuid-here
